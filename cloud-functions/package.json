{
  "name": "beacon-cloud-functions",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "type": "module",
  "scripts": {
    "dev:alert": "functions-framework --target=processIncomingAlert --port=8080",
    "dev:shelter": "functions-framework --target=checkShelterCapacity --port=8081",
