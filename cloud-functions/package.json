    "@google/generative-ai": "^0.11.4",
    "@supabase/supabase-js": "^2.43.4",
    "beacon-shared": "workspace:*",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  }
}
